---
import '../styles/globals.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Estudiemos</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  body {
    background-color: #0a0a0a;
    color: #e5e7eb;
    min-height: 100vh;
  }
</style>
