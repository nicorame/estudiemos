---
import Layout from '../layouts/Layout.astro';
import { GoogleAuthButton } from '../components/GoogleAuthButton';
---

<Layout title="Inicio">

  <!-- NAVBAR -->
  <nav class="navbar">
    <div class="nav-inner">
      <span class="nav-logo">estudiemos</span>
      <GoogleAuthButton client:load className="nav-cta" label="Ingresar" />
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-glow"></div>
    <div class="hero-inner">
      <div class="hero-badge">✦ Plataforma de aprendizaje con IA</div>
      <h1 class="hero-title">
        Aprendé más rápido,<br/>
        <span class="hero-gradient">con inteligencia</span>
      </h1>
      <p class="hero-description">
        Estudiemos combina tutorías personalizadas con IA, seguimiento de progreso
        y comunidad de estudiantes para que puedas alcanzar tus metas.
      </p>
      <div class="hero-actions">
        <GoogleAuthButton client:load className="btn-google" label="Continuar con Google" />
        <a href="#features" class="btn-ghost">Ver más ↓</a>
      </div>
    </div>

    <!-- Floating cards decorativas -->
    <div class="hero-cards">
      <div class="float-card card-1">
        <span class="card-emoji">🧠</span>
        <span>IA Personalizada</span>
      </div>
      <div class="float-card card-2">
        <span class="card-emoji">📈</span>
        <span>+40% más rápido</span>
      </div>
      <div class="float-card card-3">
        <span class="card-emoji">🎯</span>
        <span>Objetivos claros</span>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="features" id="features">
    <div class="section-inner">
      <p class="section-label">¿Qué incluye?</p>
      <h2 class="section-title">Todo lo que necesitás para aprender</h2>

      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">🤖</div>
          <h3>Tutor con IA</h3>
          <p>Claude responde tus dudas, explica conceptos y te guía paso a paso en cualquier tema.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📚</div>
          <h3>Cursos Estructurados</h3>
          <p>Contenido organizado en módulos progresivos adaptados a tu nivel y ritmo de aprendizaje.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📊</div>
          <h3>Seguimiento de Progreso</h3>
          <p>Visualizá tu avance en tiempo real, rachas de estudio y logros desbloqueados.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">👥</div>
          <h3>Comunidad</h3>
          <p>Conectá con otros estudiantes, compartí notas y resolvé ejercicios en grupo.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="how-it-works">
    <div class="section-inner">
      <p class="section-label">Simple y rápido</p>
      <h2 class="section-title">Empezá en 3 pasos</h2>

      <div class="steps">
        <div class="step">
          <div class="step-number">01</div>
          <h3>Creá tu cuenta</h3>
          <p>Ingresá con Google en segundos. Sin formularios largos ni contraseñas que recordar.</p>
        </div>
        <div class="step-arrow">→</div>
        <div class="step">
          <div class="step-number">02</div>
          <h3>Elegí tu área</h3>
          <p>Seleccioná qué querés aprender y la IA configurará tu plan de estudio personalizado.</p>
        </div>
        <div class="step-arrow">→</div>
        <div class="step">
          <div class="step-number">03</div>
          <h3>Empezá a aprender</h3>
          <p>Accedé a cursos, hacé preguntas al tutor IA y medí tu progreso desde el primer día.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="cta-section">
    <div class="cta-glow"></div>
    <div class="section-inner cta-inner">
      <h2 class="cta-title">¿Listo para empezar?</h2>
      <p class="cta-description">Más de 1.000 estudiantes ya están aprendiendo con IA. Unite hoy gratis.</p>
      <GoogleAuthButton client:load className="btn-google btn-large" label="Continuar con Google — Es gratis" />
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <span class="nav-logo">estudiemos</span>
      <p>© 2025 Estudiemos. Todos los derechos reservados.</p>
    </div>
  </footer>

</Layout>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }

  /* ---- NAVBAR ---- */
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1.25rem 0;
    background: rgba(10, 10, 10, 0.8);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-logo {
    font-size: 1.25rem;
    font-weight: 700;
    color: white;
    letter-spacing: -0.02em;
  }


  /* ---- HERO ---- */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background-color: #0a0a0a;
    overflow: hidden;
    padding: 8rem 2rem 4rem;
  }

  .hero-glow {
    position: absolute;
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 600px;
    background: radial-gradient(ellipse, rgba(99,102,241,0.3) 0%, rgba(236,72,153,0.15) 40%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
    z-index: 1;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.375rem 1rem;
    background: rgba(99,102,241,0.15);
    border: 1px solid rgba(99,102,241,0.3);
    border-radius: 2rem;
    color: #a5b4fc;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    margin-bottom: 2rem;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 800;
    color: white;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }

  .hero-gradient {
    background: linear-gradient(135deg, #6366f1, #ec4899, #f59e0b);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-description {
    font-size: 1.1rem;
    color: #9ca3af;
    line-height: 1.7;
    max-width: 540px;
    margin-bottom: 2.5rem;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }


  .btn-ghost {
    color: #9ca3af;
    font-size: 0.95rem;
    text-decoration: none;
    transition: color 0.2s;
  }

  .btn-ghost:hover {
    color: white;
    text-decoration: none;
  }

  /* Floating cards */
  .hero-cards {
    position: absolute;
    right: 2rem;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    z-index: 1;
  }

  .float-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1.25rem;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 0.875rem;
    color: white;
    font-size: 0.875rem;
    font-weight: 500;
    backdrop-filter: blur(8px);
    white-space: nowrap;
  }

  .card-emoji {
    font-size: 1.2rem;
  }

  .card-1 { animation: float 4s ease-in-out infinite; }
  .card-2 { animation: float 4s ease-in-out infinite 1.3s; }
  .card-3 { animation: float 4s ease-in-out infinite 2.6s; }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  /* ---- SECTIONS SHARED ---- */
  .section-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-label {
    color: #6366f1;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    color: white;
    letter-spacing: -0.03em;
    margin-bottom: 3rem;
    line-height: 1.15;
  }

  /* ---- FEATURES ---- */
  .features {
    padding: 7rem 2rem;
    background-color: #0d0d0d;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .feature-card {
    padding: 2rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1rem;
    transition: all 0.3s;
  }

  .feature-card:hover {
    background: rgba(99,102,241,0.08);
    border-color: rgba(99,102,241,0.3);
    transform: translateY(-4px);
  }

  .feature-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .feature-card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: white;
    margin-bottom: 0.5rem;
  }

  .feature-card p {
    font-size: 0.9rem;
    color: #6b7280;
    line-height: 1.6;
  }

  /* ---- HOW IT WORKS ---- */
  .how-it-works {
    padding: 7rem 2rem;
    background-color: #0a0a0a;
  }

  .steps {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .step {
    flex: 1;
    min-width: 200px;
  }

  .step-number {
    font-size: 3rem;
    font-weight: 900;
    color: rgba(99,102,241,0.3);
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 1rem;
  }

  .step h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: white;
    margin-bottom: 0.5rem;
  }

  .step p {
    font-size: 0.875rem;
    color: #6b7280;
    line-height: 1.6;
  }

  .step-arrow {
    font-size: 1.5rem;
    color: rgba(255,255,255,0.15);
    padding-top: 1rem;
    flex-shrink: 0;
  }

  /* ---- CTA SECTION ---- */
  .cta-section {
    position: relative;
    padding: 7rem 2rem;
    background-color: #0d0d0d;
    overflow: hidden;
    text-align: center;
  }

  .cta-glow {
    position: absolute;
    bottom: -100px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(236,72,153,0.2) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .cta-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    color: white;
    letter-spacing: -0.03em;
    margin: 0;
  }

  .cta-description {
    font-size: 1rem;
    color: #6b7280;
    margin: 0;
  }

  /* ---- FOOTER ---- */
  .footer {
    padding: 2.5rem 2rem;
    background-color: #0a0a0a;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer p {
    font-size: 0.8rem;
    color: #4b5563;
    margin: 0;
  }

  /* ---- RESPONSIVE ---- */
  @media (max-width: 768px) {
    .hero-cards {
      display: none;
    }

    .step-arrow {
      display: none;
    }

    .steps {
      flex-direction: column;
    }
  }
</style>
